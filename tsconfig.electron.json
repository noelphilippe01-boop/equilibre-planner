{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
    "include": ["electron", "src/types", "src/lib/recipeLibrary.ts", "src/lib/recipeFormat.ts", "src/lib/menuStructure.ts", "src/lib/lightMealRecipes.ts", "src/lib/guestCounts.ts"]
}
